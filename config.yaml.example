agency:
  title: Agency
  default_group: my-project
groups:
  my-project:
    name: My Project Agents
    path: /path/to/your/agents
    default_integration: claude-code
    agents:
    - name: builder
      integration: claude-code
      capabilities:
        write: true
    - name: advisor
      integration: claude-code
      capabilities:
        write: false
    - name: sentinel
      integration: claude-code
      capabilities:
        write: false
